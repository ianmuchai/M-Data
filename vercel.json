{
  "services": {
    "frontend": {
      "root": ".",
      "framework": "vite",
      "installCommand": "npm install",
      "buildCommand": "npm run build",
      "outputDirectory": "dist"
    },
    "backend": {
      "root": ".",
      "framework": "express",
      "entrypoint": "backend/server.ts",
      "installCommand": "npm install"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": { "service": "backend" } },
    { "source": "/(.*)", "destination": { "service": "frontend" } }
  ]
}
